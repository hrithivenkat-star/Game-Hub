<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mini Games — GameHub</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{--cyan:#00f5ff;--purple:#bf00ff;--pink:#ff006e;--green:#00ff88;--yellow:#ffe600;--orange:#ff6b00;--red:#ff003c;--blue:#0088ff;--bg:#050510;--card:#0a0a1a;--dim:#6677aa;}
html,body{min-height:100vh;background:var(--bg);color:#e0e8ff;font-family:'Rajdhani',sans-serif;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,245,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,255,0.025) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;}
body::after{content:'';position:fixed;top:-200px;left:50%;transform:translateX(-50%);width:800px;height:500px;background:radial-gradient(ellipse,rgba(0,245,255,0.05) 0%,transparent 70%);pointer-events:none;z-index:0;}
@keyframes scanline{0%{transform:translateY(-100%)}100%{transform:translateY(100vh)}}
.scanline{position:fixed;left:0;right:0;height:2px;background:linear-gradient(transparent,rgba(0,245,255,0.03),transparent);animation:scanline 9s linear infinite;pointer-events:none;z-index:0;}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes pulse-glow{0%,100%{opacity:0.7}50%{opacity:1}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes scoreFlash{0%{transform:scale(1.4);color:#fff}100%{transform:scale(1)}}
.container{position:relative;z-index:1;max-width:1300px;margin:0 auto;padding:0 24px;}
nav{display:flex;align-items:center;justify-content:space-between;padding:18px 0;border-bottom:1px solid rgba(0,245,255,0.08);}
.logo{font-family:'Orbitron',monospace;font-size:20px;font-weight:900;color:var(--cyan);text-decoration:none;text-shadow:0 0 20px rgba(0,245,255,0.5);}
.logo span{color:var(--purple);}
.back-btn{color:var(--dim);text-decoration:none;font-size:13px;font-weight:600;letter-spacing:1px;text-transform:uppercase;transition:all 0.2s;border:1px solid rgba(255,255,255,0.08);padding:8px 18px;border-radius:6px;}
.back-btn:hover{color:var(--cyan);border-color:rgba(0,245,255,0.3);box-shadow:0 0 12px rgba(0,245,255,0.1);}
.hero{text-align:center;padding:48px 0 40px;}
.hero-icon{width:64px;height:64px;border-radius:14px;margin:0 auto 20px;background:rgba(0,245,255,0.08);border:1px solid rgba(0,245,255,0.2);display:flex;align-items:center;justify-content:center;font-size:28px;box-shadow:0 0 25px rgba(0,245,255,0.12);animation:float 3s ease-in-out infinite;}
.hero-tag{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:var(--cyan);margin-bottom:12px;text-shadow:0 0 10px rgba(0,245,255,0.5);}
.hero h1{font-family:'Orbitron',monospace;font-size:clamp(26px,5vw,50px);font-weight:900;color:#fff;margin-bottom:12px;}
.hero h1 span{color:var(--cyan);text-shadow:0 0 25px rgba(0,245,255,0.8);}
.hero p{font-size:16px;color:var(--dim);max-width:460px;margin:0 auto 28px;line-height:1.6;}
.stats-bar{display:flex;justify-content:center;border:1px solid rgba(0,245,255,0.1);border-radius:8px;margin:0 auto 48px;max-width:520px;overflow:hidden;background:rgba(0,245,255,0.02);}
.stat-item{flex:1;padding:14px;text-align:center;border-right:1px solid rgba(0,245,255,0.07);}
.stat-item:last-child{border-right:none;}
.stat-num{font-family:'Orbitron',monospace;font-size:22px;font-weight:700;color:var(--cyan);display:block;text-shadow:0 0 12px rgba(0,245,255,0.5);}
.stat-label{font-size:10px;color:var(--dim);letter-spacing:1px;text-transform:uppercase;margin-top:3px;}
.filter-tabs{display:flex;justify-content:center;gap:8px;margin-bottom:36px;flex-wrap:wrap;}
.filter-tab{padding:7px 18px;border-radius:20px;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;border:1px solid rgba(255,255,255,0.08);color:var(--dim);background:transparent;transition:all 0.2s;font-family:'Rajdhani',sans-serif;}
.filter-tab:hover{border-color:rgba(255,255,255,0.2);color:#fff;}
.filter-tab.active{background:rgba(0,245,255,0.1);border-color:rgba(0,245,255,0.3);color:var(--cyan);box-shadow:0 0 12px rgba(0,245,255,0.15);}
.section-header{margin-bottom:20px;display:flex;align-items:center;gap:14px;}
.section-title{font-family:'Orbitron',monospace;font-size:16px;font-weight:700;color:#fff;}
.section-line{flex:1;height:1px;background:rgba(255,255,255,0.05);}
.section-count{font-size:11px;color:var(--dim);}
.games-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px;}
.game-card{position:relative;overflow:hidden;background:var(--card);border-radius:12px;border:1px solid rgba(255,255,255,0.05);text-decoration:none;color:inherit;transition:all 0.28s;display:flex;flex-direction:column;animation:fadeInUp 0.4s ease both;}
.game-card:hover{transform:translateY(-5px);}
.card-bar{height:3px;border-radius:12px 12px 0 0;flex-shrink:0;}
.game-card[data-color="green"]  .card-bar{background:var(--green);box-shadow:0 0 10px var(--green);}
.game-card[data-color="cyan"]   .card-bar{background:var(--cyan);box-shadow:0 0 10px var(--cyan);}
.game-card[data-color="purple"] .card-bar{background:var(--purple);box-shadow:0 0 10px var(--purple);}
.game-card[data-color="pink"]   .card-bar{background:var(--pink);box-shadow:0 0 10px var(--pink);}
.game-card[data-color="yellow"] .card-bar{background:var(--yellow);box-shadow:0 0 10px var(--yellow);}
.game-card[data-color="orange"] .card-bar{background:var(--orange);box-shadow:0 0 10px var(--orange);}
.game-card[data-color="red"]    .card-bar{background:var(--red);box-shadow:0 0 10px var(--red);}
.game-card[data-color="blue"]   .card-bar{background:var(--blue);box-shadow:0 0 10px var(--blue);}
.game-card[data-color="green"]:hover  {box-shadow:0 16px 40px rgba(0,255,136,0.12),0 0 0 1px rgba(0,255,136,0.2);border-color:rgba(0,255,136,0.18);}
.game-card[data-color="cyan"]:hover   {box-shadow:0 16px 40px rgba(0,245,255,0.12),0 0 0 1px rgba(0,245,255,0.2);border-color:rgba(0,245,255,0.18);}
.game-card[data-color="purple"]:hover {box-shadow:0 16px 40px rgba(191,0,255,0.12),0 0 0 1px rgba(191,0,255,0.2);border-color:rgba(191,0,255,0.18);}
.game-card[data-color="pink"]:hover   {box-shadow:0 16px 40px rgba(255,0,110,0.12),0 0 0 1px rgba(255,0,110,0.2);border-color:rgba(255,0,110,0.18);}
.game-card[data-color="yellow"]:hover {box-shadow:0 16px 40px rgba(255,230,0,0.12),0 0 0 1px rgba(255,230,0,0.2);border-color:rgba(255,230,0,0.18);}
.game-card[data-color="orange"]:hover {box-shadow:0 16px 40px rgba(255,107,0,0.12),0 0 0 1px rgba(255,107,0,0.2);border-color:rgba(255,107,0,0.18);}
.game-card[data-color="red"]:hover    {box-shadow:0 16px 40px rgba(255,0,60,0.12),0 0 0 1px rgba(255,0,60,0.2);border-color:rgba(255,0,60,0.18);}
.game-card[data-color="blue"]:hover   {box-shadow:0 16px 40px rgba(0,136,255,0.12),0 0 0 1px rgba(0,136,255,0.2);border-color:rgba(0,136,255,0.18);}
.card-body{padding:18px 16px 14px;flex:1;display:flex;flex-direction:column;}
.game-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:12px;flex-shrink:0;}
.game-card[data-color="green"]  .game-icon{background:rgba(0,255,136,0.1);border:1px solid rgba(0,255,136,0.22);}
.game-card[data-color="cyan"]   .game-icon{background:rgba(0,245,255,0.1);border:1px solid rgba(0,245,255,0.22);}
.game-card[data-color="purple"] .game-icon{background:rgba(191,0,255,0.1);border:1px solid rgba(191,0,255,0.22);}
.game-card[data-color="pink"]   .game-icon{background:rgba(255,0,110,0.1);border:1px solid rgba(255,0,110,0.22);}
.game-card[data-color="yellow"] .game-icon{background:rgba(255,230,0,0.1);border:1px solid rgba(255,230,0,0.22);}
.game-card[data-color="orange"] .game-icon{background:rgba(255,107,0,0.1);border:1px solid rgba(255,107,0,0.22);}
.game-card[data-color="red"]    .game-icon{background:rgba(255,0,60,0.1);border:1px solid rgba(255,0,60,0.22);}
.game-card[data-color="blue"]   .game-icon{background:rgba(0,136,255,0.1);border:1px solid rgba(0,136,255,0.22);}
.difficulty-badge{position:absolute;top:14px;right:12px;font-size:9px;font-weight:600;letter-spacing:1px;text-transform:uppercase;padding:3px 8px;border-radius:8px;}
.badge-easy  {background:rgba(0,255,136,0.1);color:var(--green);border:1px solid rgba(0,255,136,0.2);}
.badge-medium{background:rgba(255,230,0,0.1);color:var(--yellow);border:1px solid rgba(255,230,0,0.2);}
.badge-hard  {background:rgba(255,0,110,0.1);color:var(--pink);border:1px solid rgba(255,0,110,0.2);}
.game-card h3{font-family:'Orbitron',monospace;font-size:13px;font-weight:700;color:#fff;margin-bottom:6px;letter-spacing:0.5px;}
.game-card p{font-size:13px;color:var(--dim);line-height:1.5;margin-bottom:14px;flex:1;}
.score-row{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.03);border-radius:6px;padding:7px 10px;margin-bottom:12px;border:1px solid rgba(255,255,255,0.04);}
.score-label{font-size:10px;color:var(--dim);letter-spacing:1px;text-transform:uppercase;}
.score-val{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;animation:pulse-glow 2.5s ease-in-out infinite;transition:all 0.3s;}
.game-card[data-color="green"]  .score-val{color:var(--green);}
.game-card[data-color="cyan"]   .score-val{color:var(--cyan);}
.game-card[data-color="purple"] .score-val{color:var(--purple);}
.game-card[data-color="pink"]   .score-val{color:var(--pink);}
.game-card[data-color="yellow"] .score-val{color:var(--yellow);}
.game-card[data-color="orange"] .score-val{color:var(--orange);}
.game-card[data-color="red"]    .score-val{color:var(--red);}
.game-card[data-color="blue"]   .score-val{color:var(--blue);}
.score-flash{animation:scoreFlash 0.5s ease-out!important;}
.card-footer{padding:10px 16px;border-top:1px solid rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.01);}
.controls-hint{font-size:10px;color:var(--dim);}
.play-btn{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:7px 14px;border-radius:5px;cursor:pointer;transition:all 0.2s;text-decoration:none;display:inline-block;border:none;}
.game-card[data-color="green"]  .play-btn{background:rgba(0,255,136,0.1);color:var(--green);border:1px solid rgba(0,255,136,0.25);}
.game-card[data-color="cyan"]   .play-btn{background:rgba(0,245,255,0.1);color:var(--cyan);border:1px solid rgba(0,245,255,0.25);}
.game-card[data-color="purple"] .play-btn{background:rgba(191,0,255,0.1);color:var(--purple);border:1px solid rgba(191,0,255,0.25);}
.game-card[data-color="pink"]   .play-btn{background:rgba(255,0,110,0.1);color:var(--pink);border:1px solid rgba(255,0,110,0.25);}
.game-card[data-color="yellow"] .play-btn{background:rgba(255,230,0,0.1);color:var(--yellow);border:1px solid rgba(255,230,0,0.25);}
.game-card[data-color="orange"] .play-btn{background:rgba(255,107,0,0.1);color:var(--orange);border:1px solid rgba(255,107,0,0.25);}
.game-card[data-color="red"]    .play-btn{background:rgba(255,0,60,0.1);color:var(--red);border:1px solid rgba(255,0,60,0.25);}
.game-card[data-color="blue"]   .play-btn{background:rgba(0,136,255,0.1);color:var(--blue);border:1px solid rgba(0,136,255,0.25);}
.game-card:hover .play-btn{filter:brightness(1.3);transform:scale(1.05);}
footer{border-top:1px solid rgba(0,245,255,0.06);padding:28px 0;text-align:center;margin-top:40px;}
footer p{font-size:13px;color:var(--dim);}
footer a{color:var(--cyan);text-decoration:none;}
</style>
</head>
<body>
<div class="scanline"></div>
<div class="container">
  <nav>
    <a href="../index.html" class="logo">GAME<span>HUB</span></a>
    <a href="../index.html" class="back-btn">← Back to Hub</a>
  </nav>
  <section class="hero">
    <div class="hero-icon">🎮</div>
    <p class="hero-tag">⚡ Arcade Collection</p>
    <h1>MINI <span>GAMES</span></h1>
    <p>15 neon arcade games. Classic and original. Pick your game and beat your high score.</p>
  </section>
  <div class="stats-bar">
    <div class="stat-item"><span class="stat-num">15</span><div class="stat-label">Games</div></div>
    <div class="stat-item"><span class="stat-num" id="scores-set">0</span><div class="stat-label">Scores Set</div></div>
    <div class="stat-item"><span class="stat-num" id="total-plays">0</span><div class="stat-label">Total Plays</div></div>
  </div>
  <div class="filter-tabs">
    <button class="filter-tab active" onclick="filterGames(this,'all')">All Games</button>
    <button class="filter-tab" onclick="filterGames(this,'classic')">Classics</button>
    <button class="filter-tab" onclick="filterGames(this,'action')">Action</button>
    <button class="filter-tab" onclick="filterGames(this,'puzzle')">Puzzle</button>
    <button class="filter-tab" onclick="filterGames(this,'easy')">Easy</button>
    <button class="filter-tab" onclick="filterGames(this,'hard')">Hard</button>
  </div>
  <div class="section-header">
    <div class="section-title">Original Five</div>
    <div class="section-line"></div>
    <div class="section-count">5 games</div>
  </div>
  <div class="games-grid">
    <a href="snake/index.html" class="game-card" data-color="green" data-cat="classic action" data-diff="easy">
      <div class="card-bar"></div><span class="difficulty-badge badge-easy">Easy</span>
      <div class="card-body"><div class="game-icon">🐍</div><h3>Snake</h3><p>Eat the food, grow your snake. Don't hit the walls or yourself.</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-snake">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Arrow / WASD</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="tetris/index.html" class="game-card" data-color="cyan" data-cat="classic puzzle" data-diff="medium">
      <div class="card-bar"></div><span class="difficulty-badge badge-medium">Medium</span>
      <div class="card-body"><div class="game-icon">🟦</div><h3>Tetris</h3><p>Stack the falling blocks. Clear the lines. Speed increases with level.</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-tetris">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Arrow + Space</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="pong/index.html" class="game-card" data-color="purple" data-cat="classic action" data-diff="easy">
      <div class="card-bar"></div><span class="difficulty-badge badge-easy">Easy</span>
      <div class="card-body"><div class="game-icon">🏓</div><h3>Pong</h3><p>Rally against the AI. First to 7 wins. The AI gets faster over time.</p>
      <div class="score-row"><span class="score-label">🏆 Wins</span><span class="score-val" id="s-pong">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">W / S keys</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="breakout/index.html" class="game-card" data-color="pink" data-cat="classic action" data-diff="medium">
      <div class="card-bar"></div><span class="difficulty-badge badge-medium">Medium</span>
      <div class="card-body"><div class="game-icon">🧱</div><h3>Breakout</h3><p>Smash every brick without dropping the ball. 3 lives. Don't let it fall.</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-breakout">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Arrow / Mouse</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="2048/index.html" class="game-card" data-color="yellow" data-cat="classic puzzle" data-diff="medium">
      <div class="card-bar"></div><span class="difficulty-badge badge-medium">Medium</span>
      <div class="card-body"><div class="game-icon">🔢</div><h3>2048</h3><p>Merge matching tiles. Reach 2048 and beyond. Simple to learn, hard to master.</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-2048">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Arrow / Swipe</span><span class="play-btn">Play →</span></div>
    </a>
  </div>
  <div class="section-header" style="margin-top:12px">
    <div class="section-title">New Arrivals</div>
    <div class="section-line"></div>
    <div class="section-count">10 games</div>
  </div>
  <div class="games-grid">
    <a href="flappy-bird/index.html" class="game-card" data-color="green" data-cat="action" data-diff="hard">
      <div class="card-bar"></div><span class="difficulty-badge badge-hard">Hard</span>
      <div class="card-body"><div class="game-icon">🐦</div><h3>Flappy Bird</h3><p>Tap to fly. Dodge the neon pipes. One touch is all it takes to die.</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-flappy">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Space / Tap</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="space-invaders/index.html" class="game-card" data-color="cyan" data-cat="action" data-diff="medium">
      <div class="card-bar"></div><span class="difficulty-badge badge-medium">Medium</span>
      <div class="card-body"><div class="game-icon">👾</div><h3>Space Invaders</h3><p>Shoot the alien waves before they reach you. Get harder with every level.</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-space">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Arrow + Space</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="pacman/index.html" class="game-card" data-color="yellow" data-cat="classic action" data-diff="medium">
      <div class="card-bar"></div><span class="difficulty-badge badge-medium">Medium</span>
      <div class="card-body"><div class="game-icon">🟡</div><h3>Pac-Man</h3><p>Eat all the dots. Dodge the neon ghosts. Power up and hunt them back.</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-pacman">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Arrow / WASD</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="doodle-jump/index.html" class="game-card" data-color="orange" data-cat="action" data-diff="easy">
      <div class="card-bar"></div><span class="difficulty-badge badge-easy">Easy</span>
      <div class="card-body"><div class="game-icon">🦘</div><h3>Doodle Jump</h3><p>Bounce from platform to platform. How high can you go before you fall?</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-doodle">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Arrow / Tilt</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="cyber-runner/index.html" class="game-card" data-color="purple" data-cat="action" data-diff="medium">
      <div class="card-bar"></div><span class="difficulty-badge badge-medium">Medium</span>
      <div class="card-body"><div class="game-icon">🏃</div><h3>Cyber Runner</h3><p>Endless neon runner. Jump over obstacles. Speed increases every 10 seconds.</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-runner">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Space / Tap</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="memory-match/index.html" class="game-card" data-color="blue" data-cat="puzzle" data-diff="easy">
      <div class="card-bar"></div><span class="difficulty-badge badge-easy">Easy</span>
      <div class="card-body"><div class="game-icon">🃏</div><h3>Memory Match</h3><p>Flip and match neon symbol cards. Clear the board in the fewest moves.</p>
      <div class="score-row"><span class="score-label">🏆 Best</span><span class="score-val" id="s-memory">--</span></div></div>
      <div class="card-footer"><span class="controls-hint">Click / Tap</span><span class="play-btn">Play →</span></div>
    </a>
    <a href="rps/index.html" class="game-card" data-color="pink" data-cat="puzzle" data-diff="easy">
