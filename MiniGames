<script>
// localStorage keys — MUST match exactly what each game saves
const scoreMap = {
  's-snake':'snake_best','s-tetris':'tetris_best','s-pong':'pong_wins',
  's-breakout':'breakout_best','s-2048':'2048_best','s-flappy':'flappy_best',
  's-space':'space_best','s-pacman':'pacman_best','s-doodle':'doodle_best',
  's-runner':'runner_best','s-memory':'memory_best','s-rps':'rps_wins',
  's-whack':'whack_best','s-ttt':'ttt_wins','s-mine':'mine_best',
};
function loadScores() {
  let scoresSet = 0;
  for (const [elId, key] of Object.entries(scoreMap)) {
    const val = localStorage.getItem(key);
    const el = document.getElementById(elId);
    if (!el) continue;
    if (val !== null) {
      const display = Number(val).toLocaleString();
      if (el.textContent !== display) {
        el.textContent = display;
        el.classList.remove('score-flash');
        void el.offsetWidth;
        el.classList.add('score-flash');
      }
      scoresSet++;
    } else { if (el.textContent !== '--') el.textContent = '--'; }
  }
  document.getElementById('scores-set').textContent = scoresSet;
  document.getElementById('total-plays').textContent = localStorage.getItem('total_plays') || '0';
}
function filterGames(btn, type) {
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.game-card').forEach(card => {
    const cat = card.dataset.cat||'', diff = card.dataset.diff||'';
    const show = type==='all'?true:type==='easy'?diff==='easy':type==='hard'?diff==='hard':cat.includes(type);
    card.style.display = show ? 'flex' : 'none';
  });
}
loadScores();
setInterval(loadScores, 2000);
document.addEventListener('visibilitychange', () => { if (!document.hidden) loadScores(); });
</script>
